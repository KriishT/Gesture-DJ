# Copy this file to .env and fill in your key.
# The key is used server-side only and never exposed to the browser.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
# COPILOT_MODEL=claude-haiku-4-5
# COPILOT_MAX_TOKENS=3000
# API_PORT=8787

# GPU stem separation (HTDemucs 6-stem, ~5-15s per track on NVIDIA GPU)
# Install once: pip install -r server/stems/requirements.txt
# Use CUDA PyTorch: https://pytorch.org/get-started/locally/
# STEM_PYTHON=python

# Cloud stem fallback (when no local NVIDIA GPU) — uses Replicate API (~10-60s, paid)
# Get a token at https://replicate.com/account/api-tokens
# Pick a Demucs model version from replicate.com — paste the version hash below
# REPLICATE_API_TOKEN=r8_...
# REPLICATE_DEMUX_VERSION=5a7041cc9b82e5a558fea6b3d7b12dea89625e89da33f0447bd727c2d0ab9e77
# REPLICATE_DEMUX_MODEL=htdemucs_6s     # 6 stems (vocals, drums, bass, other, guitar, piano)
# STEMS_CLOUD_ONLY=1                    # force Replicate even if local CUDA is available (for testing)

# Production deploy
# NODE_ENV=production
# SERVE_STATIC=1          # serve dist/ from Express (single-host deploy)
# CORS_ORIGIN=https://your-app.example.com   # split frontend/API hosts
