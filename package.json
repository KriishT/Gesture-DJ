{
  "name": "gesture-dj",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Control two DJ decks with hand gestures, guided by an AI co-pilot.",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"npm:server\"",
    "server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.20",
    "@soundtouchjs/audio-worklet": "^2.0.3",
    "html2canvas": "^1.4.1",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "web-audio-beat-detector": "^8.2.18",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
